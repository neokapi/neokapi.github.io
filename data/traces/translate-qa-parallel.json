      "ts": 590,
      "type": "enter",
      "nodeId": "tool-1",
      "partId": "block-heading",
      "meta": { "worker": 0 }
    },
    {
      "ts": 600,
      "type": "enter",
      "nodeId": "tool-1",
      "partId": "block-body",
      "meta": { "worker": 1 }
