{
  "name": "Translate + QA (Parallel)",
  "description": "AI translate followed by QA check, both with --parallel-blocks 2: two concurrent stages each processing blocks in parallel",
  "nodes": [
    { "id": "reader", "type": "reader", "name": "json", "label": "JSON Reader" },
    {
      "id": "tool-0",
      "type": "tool",
      "name": "translate",
      "label": "AI Translate",
      "concurrency": 2
    },
    {
      "id": "tool-1",
      "type": "tool",
      "name": "qa",
      "label": "AI QA Check",
      "concurrency": 2
    },
    { "id": "writer", "type": "writer", "name": "json", "label": "JSON Writer" }
  ],
  "channelSize": 64,
  "events": [
    { "ts": 50, "type": "exit", "nodeId": "reader", "partId": "layer-1" },
    { "ts": 100, "type": "exit", "nodeId": "reader", "partId": "block-heading" },
    { "ts": 120, "type": "exit", "nodeId": "reader", "partId": "block-body" },
