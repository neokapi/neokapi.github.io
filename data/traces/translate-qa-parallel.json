    { "ts": 870, "type": "exit", "nodeId": "writer", "partId": "block-heading" },

    {
      "ts": 880,
      "type": "exit",
      "nodeId": "tool-0",
      "partId": "block-footer",
      "meta": { "parallel": true, "worker": 0 }
